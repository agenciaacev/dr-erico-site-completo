# Renomeie este arquivo para .env.local e configure suas chaves.
# As variáveis NEXT_PUBLIC_ também devem ser adicionadas nas
# Environment Variables do projeto na Vercel (Settings → Environment Variables).

# ── YouTube ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_YOUTUBE_API_KEY=AIzaSyBMWHaZ036FcFLxOOmLDIkKF2p-2KUWT-4
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=UCITORRpgYFysxixfAa623yQ

# ── Google Tag Manager ───────────────────────────────────────────────────────
# Encontre em: tagmanager.google.com → Conta → Contêiner → ID (formato GTM-XXXXXXX)
# OBRIGATÓRIO para manter rastreamento GA4 e conversões após a migração.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Meta Pixel (Facebook/Instagram Ads) ─────────────────────────────────────
# Encontre em: business.facebook.com → Gerenciador de Eventos → Pixel → ID
NEXT_PUBLIC_META_PIXEL_ID=
